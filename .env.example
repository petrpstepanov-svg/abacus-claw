# =============================================
# AutoHub Rostov — Environment Variables
# =============================================
# Скопируйте этот файл в .env и заполните реальными значениями.
# НИКОГДА не коммитьте .env с реальными кредами!

# --- PostgreSQL (Neon / Supabase / Railway) ---
# Строка подключения к БД
DATABASE_URL="postgresql://user:password@host:5432/database?schema=public"

# --- Telegram Bot ---
# Токен бота от @BotFather
TELEGRAM_BOT_TOKEN="your_bot_token_here"
# ID чата/группы для уведомлений
TELEGRAM_CHAT_ID="your_chat_id_here"

# --- SMS Aero ---
# Email аккаунта SMS Aero
SMS_AERO_EMAIL="your_email_here"
# API-ключ SMS Aero
SMS_AERO_API_KEY="your_api_key_here"

# --- Site URL ---
# Публичный URL сайта (для SEO и OG-меток)
NEXT_PUBLIC_SITE_URL="https://avtohub161.ru"


# --- Admin ---
# Пароль для доступа к админ-панели (/admin)
ADMIN_PASSWORD="your_admin_password_here"
